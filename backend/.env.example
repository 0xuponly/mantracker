# App
DEBUG=false

# Database (default: SQLite in backend dir)
# DATABASE_URL=sqlite+aiosqlite:///./portfolio.db

# Encryption for API keys and wallet addresses (strongly recommended in production)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=your-base64-fernet-key

# JWT secret (change in production)
# SECRET_KEY=your-secret-key

# Covalent (optional – full EVM token balances; without key, only native token)
# COVALENT_API_KEY=

# Solana RPC (optional – public RPC is rate-limited; set for higher limits, e.g. Helius/QuickNode)
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
